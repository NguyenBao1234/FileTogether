<Window x:Class="FileTogether.Client.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:FileTogether.Client"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Create New Account" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center"/>
        
        <!-- Server Info -->
        <GroupBox Header="Server Connection" Grid.Row="2" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Server IP:" VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox x:Name="txtServerIP" Text="127.0.0.1" Grid.Column="1" 
                         Height="25" VerticalContentAlignment="Center" Margin="5,0"/>
                
                <TextBlock Text="Port:" VerticalAlignment="Center" Grid.Column="2" 
                           Margin="10,0,5,0"/>
                <TextBox x:Name="txtPort" Text="2121" Grid.Column="3" 
                         Height="25" VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>
        
        <!-- Registration Form -->
        <GroupBox Header="Account Information" Grid.Row="3" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Username -->
                <TextBlock Text="Username:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                <TextBox x:Name="txtUsername" Grid.Row="0" Grid.Column="1" 
                         Height="25" VerticalContentAlignment="Center" Margin="5,0"
                         TextChanged="TxtUsername_TextChanged"/>
                
                <!-- Password -->
                <TextBlock Text="Password:" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0"/>
                <PasswordBox x:Name="txtPassword" Grid.Row="2" Grid.Column="1" 
                             Height="25" VerticalContentAlignment="Center" Margin="5,0"
                             PasswordChanged="TxtPassword_PasswordChanged"/>
                
                <!-- Confirm Password -->
                <TextBlock Text="Confirm Password:" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0"/>
                <PasswordBox x:Name="txtConfirmPassword" Grid.Row="4" Grid.Column="1" 
                             Height="25" VerticalContentAlignment="Center" Margin="5,0"
                             PasswordChanged="TxtConfirmPassword_PasswordChanged"
                             KeyDown="TxtConfirmPassword_KeyDown"/>
            </Grid>
        </GroupBox>
        
        <!-- Status & Hints -->
        <StackPanel Grid.Row="6" Margin="0,10,0,0">
            <TextBlock x:Name="txtStatus" 
                       Foreground="Red" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <TextBlock TextAlignment="Center" Foreground="Gray" TextWrapping="Wrap">
                <Run Text="Username: 3-20 characters"/>
                <LineBreak/>
                <Run Text="Password: Minimum 6 characters"/>
            </TextBlock>
        </StackPanel>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnRegister" Content="Register" Width="120" Height="35" 
                    Margin="0,0,10,0" Click="BtnRegister_Click" 
                    IsDefault="True" FontWeight="Bold"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="120" Height="35" 
                    Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
