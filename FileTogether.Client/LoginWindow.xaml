<Window x:Class="FileTogether.Client.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:FileTogether.Client"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="FTP Server Login" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center"/>
        
        <!-- Server Info -->
        <GroupBox Header="Server Connection" Grid.Row="2" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Server IP:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                <TextBox x:Name="txtServerIP" Text="127.0.0.1" Grid.Row="0" Grid.Column="1" 
                         Height="25" VerticalContentAlignment="Center" Margin="5,0"/>
                
                <TextBlock Text="Port:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="2" 
                           Margin="10,0,5,0"/>
                <TextBox x:Name="txtPort" Text="2121" Grid.Row="0" Grid.Column="3" 
                         Height="25" VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>
        
        <!-- Login Credentials -->
        <GroupBox Header="Login Credentials" Grid.Row="3" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Username:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                <TextBox x:Name="txtUsername" Text="admin" Grid.Row="0" Grid.Column="1" 
                         Height="25" VerticalContentAlignment="Center" Margin="5,0"/>
                
                <TextBlock Text="Password:" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0"/>
                <PasswordBox x:Name="txtPassword" Grid.Row="2" Grid.Column="1" 
                             Height="25" VerticalContentAlignment="Center" Margin="5,0"
                             KeyDown="TxtPassword_KeyDown"/>
            </Grid>
        </GroupBox>
        
        <!-- Status Message -->
        <TextBlock x:Name="txtStatus" Grid.Row="6" 
                   Foreground="Red" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnLogin" Content="Login" Width="120" Height="35" 
                    Margin="0,0,10,0" Click="BtnLogin_Click" 
                    IsDefault="True" FontWeight="Bold"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="120" Height="35" 
                    Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
        
        <!-- Help Text -->
        <TextBlock Grid.Row="8" TextAlignment="Center" Foreground="Gray" 
                   Margin="0,10,0,0" TextWrapping="Wrap">
            <Run Text="Default accounts:"/>
            <LineBreak/>
            <Run Text="Admin: admin / admin123"/>
            <LineBreak/>
            <Run Text="User: user / user123"/>
        </TextBlock>
    </Grid>
</Window>
